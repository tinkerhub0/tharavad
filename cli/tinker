#!/bin/bash
# tinker-cli — TinkerHub Kerala community server tools
# Install: cp tinker /usr/local/bin/tinker && chmod 755 /usr/local/bin/tinker

PORTS_DIR="/var/tinker/ports"
CADDY_DIR="/var/tinker/caddy"
CADDY_MAIN="/etc/caddy/users.d"
PORT_START=10000
PORT_END=60000

mkdir -p "$PORTS_DIR" "$CADDY_DIR" "$CADDY_MAIN"

cmd_help() {
  cat << EOF
tinker — TinkerHub Kerala community server CLI

  tinker port                      reserve a random port
  tinker port list                 show your reserved ports
  tinker port release <port>       free a port

  tinker caddy <subdomain> <port>  expose port at subdomain.tharavad.xyz
  tinker caddy list                show your active subdomains
  tinker caddy remove <subdomain>  take a subdomain offline

  tinker help                      show this help

examples:
  tinker port                      → 45320
  tinker caddy blog 45320          → blog.tharavad.xyz
  tinker caddy api 45321           → api.tharavad.xyz
  tinker caddy remove blog         → takes blog.tharavad.xyz offline

note: unused ports are auto-released after 7 days of inactivity.
EOF
}

cmd_port() {
  local user
  user=$(whoami)

  if [[ "$1" == "list" ]]; then
    echo "Your reserved ports:"
    grep "^$user " "$PORTS_DIR/ports" 2>/dev/null | awk '{print $2}' || echo "  none"
    return
  fi

  if [[ "$1" == "release" ]]; then
    local port="$2"
    if [[ -z "$port" ]]; then
      echo "Usage: tinker port release <port>" >&2
      exit 1
    fi
    if ! grep -q "^$user $port " "$PORTS_DIR/ports" 2>/dev/null; then
      echo "Error: port $port not allocated to you." >&2
      exit 1
    fi
    sed -i "/^$user $port /d" "$PORTS_DIR/ports"
    fuser -k "${port}/tcp" 2>/dev/null
    rm -f "$CADDY_DIR/${user}-${port}.conf"
    reload_caddy
    echo "Released port $port"
    return
  fi

  # Find a free port (not already allocated globally, not in use)
  for i in $(seq $PORT_START $PORT_END | shuf); do
    if ! grep -q " $i$" "$PORTS_DIR/ports" 2>/dev/null && ! ss -tlnp | grep -q ":$i "; then
      echo "$user $i $(date +%s)" >> "$PORTS_DIR/ports"
      echo "$i"
      return
    fi
  done

  echo "Error: no free ports available" >&2
  exit 1
}

cmd_caddy() {
  local user
  user=$(whoami)

  if [[ "$1" == "list" ]]; then
    echo "Your active subdomains:"
    ls "$CADDY_DIR/${user}-"*.conf 2>/dev/null | while read f; do
      grep "^http://" "$f" | sed 's/http:\/\//  /;s/ {//'
    done || echo "  none"
    return
  fi

  if [[ "$1" == "remove" ]]; then
    local subdomain="$2"
    if [[ -z "$subdomain" ]]; then
      echo "Usage: tinker caddy remove <subdomain>" >&2
      exit 1
    fi
    rm -f "$CADDY_DIR/${user}-${subdomain}.conf"
    reload_caddy
    echo "Removed: $subdomain.tharavad.xyz"
    return
  fi

  # tinker caddy <subdomain> <port>
  local subdomain="$1"
  local port="$2"

  if [[ -z "$subdomain" || -z "$port" ]]; then
    echo "Usage: tinker caddy <subdomain> <port>" >&2
    echo "       tinker caddy list" >&2
    echo "       tinker caddy remove <subdomain>" >&2
    exit 1
  fi

  # Only allow alphanumeric and hyphens in subdomain
  if [[ ! "$subdomain" =~ ^[a-z0-9-]+$ ]]; then
    echo "Error: subdomain must be lowercase letters, numbers, hyphens only." >&2
    exit 1
  fi

  # Verify port belongs to user
  if ! grep -q "^$user $port " "$PORTS_DIR/ports" 2>/dev/null; then
    echo "Error: port $port not reserved for you. Run 'tinker port' first." >&2
    exit 1
  fi

  cat > "$CADDY_DIR/${user}-${subdomain}.conf" << EOF
http://$subdomain.tharavad.xyz {
  reverse_proxy localhost:$port
}
EOF

  reload_caddy
  echo "Live at https://$subdomain.tharavad.xyz"
}

reload_caddy() {
  # Merge all user configs into caddy users.d directory
  cp "$CADDY_DIR"/*.conf "$CADDY_MAIN"/ 2>/dev/null
  sudo /usr/bin/caddy reload --config /etc/caddy/Caddyfile 2>/dev/null || true
}

case "$1" in
  port)    shift; cmd_port "$@" ;;
  caddy)   shift; cmd_caddy "$@" ;;
  help|"") cmd_help ;;
  *)       echo "Unknown command: $1"; cmd_help; exit 1 ;;
esac
